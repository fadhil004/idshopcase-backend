PORT=5000
NODE_ENV=production

JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_64

# ── Database ───────────────────────────────────────────────────
# When running in Docker, DB_HOST should be "postgres" (the service name)
# DATABASE_URL takes priority if set
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/idshopcase
DB_USER=postgres
DB_PASS=CHANGE_ME
DB_NAME=idshopcase
DB_HOST=postgres
DB_PORT=5432

# ── Email ──────────────────────────────────────────────────────
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_app_password

# ── Redis ──────────────────────────────────────────────────────
# In Docker, use the service name "redis"
REDIS_URL=redis://redis:6379

# ── URLs ───────────────────────────────────────────────────────
FRONTEND_URL=https://idshopcase.com
APP_BASE_URL=https://api.idshopcase.com

# ── DOKU Payment ───────────────────────────────────────────────
DOKU_CLIENT_ID=your_doku_client_id
DOKU_SECRET_KEY=your_doku_secret_key
DOKU_MERCHANT_URL=https://api.doku.com/checkout/v1/payment

# ── JNT Shipping ──────────────────────────────────────────────
JNT_USERNAME=your_jnt_username
JNT_API_KEY_ORDER=your_jnt_api_key_order
JNT_KEY_ORDER=your_jnt_order_key
JNT_KEY_CANCEL=your_jnt_cancel_key
JNT_KEY_TARIFF=your_jnt_tariff_key
JNT_PW_TRACK=your_jnt_track_password
JNT_API_KEY_CANCEL=your_jnt_api_key_cancel

JNT_ORDER_URL=
JNT_CANCEL_URL=
JNT_TARIFF_URL=
JNT_TRACK_URL=
JNT_ORIGIN_CODE=CIB

# ── Shipper ────────────────────────────────────────────────────
SHIPPER_PHONE=+6281234567890
SHIPPER_ADDRESS=Your warehouse address here

# ── Admin ──────────────────────────────────────────────────────
PASS_ADMIN=your_strong_admin_password
